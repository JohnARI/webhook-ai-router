# webhook-ai-router — environment template.
# Copy to .env and override per environment. All values have dev defaults
# in src/webhook_ai_router/config.py; production should override at minimum
# APP_ENV and the connection URLs.

# Runtime profile. One of: dev, prod.
# Controls log format (console-pretty vs JSON) and any future
# environment-specific behaviour.
APP_ENV=dev

# Logging verbosity. One of: DEBUG, INFO, WARNING, ERROR, CRITICAL.
LOG_LEVEL=INFO

# Redis connection string (idempotency cache + arq queue backend).
REDIS_URL=redis://localhost:6379/0

# Postgres connection string. Must be the asyncpg driver — sync drivers
# will not work because everything is async.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/webhook_ai_router
