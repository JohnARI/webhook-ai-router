# webhook-ai-router — environment template.
# Copy to .env and override per environment. All values have dev defaults
# in src/webhook_ai_router/config.py;
# production should override at minimum APP_ENV, the connection URLs,
# ANTHROPIC_API_KEY, HUBSPOT_WEBHOOK_SECRET, and DISPATCH_TARGETS.

# --- Runtime ---------------------------------------------------------------

# Runtime profile. One of: dev, prod.
# Controls log format (console-pretty vs JSON) and any future
# environment-specific behaviour.
APP_ENV=dev

# Logging verbosity. One of: DEBUG, INFO, WARNING, ERROR, CRITICAL.
LOG_LEVEL=INFO

# Redis connection string (idempotency cache + arq queue backend).
REDIS_URL=redis://localhost:6379/0

# Postgres connection string. Must be the asyncpg driver — sync drivers
# will not work because everything is async.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/webhook_ai_router

# --- Webhook secrets -------------------------------------------------------

# HMAC shared secret for HubSpot webhook signature verification.
HUBSPOT_WEBHOOK_SECRET=ci-test-secret

# --- LLM enrichment --------------------------------------------------------

# LLM_PROVIDER selects the active classifier:
#   anthropic → uses ANTHROPIC_API_KEY + ANTHROPIC_MODEL
#   gemini    → uses GEMINI_API_KEY + GEMINI_MODEL
# Only the active provider's key needs to be set; the worker fails fast at
# startup if it isn't.
LLM_PROVIDER=anthropic

# Anthropic — used when LLM_PROVIDER=anthropic.
# Sonnet 4.6 is the recommended speed/intelligence trade-off; bump the
# model env var to an Opus tier for higher accuracy.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# Gemini — used when LLM_PROVIDER=gemini.
# Flash is cheaper/faster (the reason to pick Gemini); for parity-on-
# quality with Sonnet 4.6 set GEMINI_MODEL=gemini-2.5-pro.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Per-call timeout for the LLM (seconds). Tenacity retries transient errors
# above this. Applies to whichever provider is active.
LLM_TIMEOUT_SECONDS=10

# --- Downstream dispatch ---------------------------------------------------

# JSON array of dispatch targets the worker forwards enriched events to.
# Each entry: {"url": "...", "method": "POST", "headers": {"X-Auth": "..."}}.
# Method defaults to POST; headers default to {}.
DISPATCH_TARGETS=[{"url":"https://webhook.site/UUID"}]

# Hard wall-clock budget for retries against a single target (seconds).
# Anything beyond this lands in the DLQ (placeholder today, real DLQ in
# a later session).
DISPATCH_TOTAL_TIMEOUT_SECONDS=120
